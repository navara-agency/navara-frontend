# Navara Frontend — Environment Variables
# Copy this file to .env and fill in real values before starting dev

# Booking link (Calendly or equivalent) — placeholder '#' until real URL provided
VITE_BOOKING_URL=#

# WhatsApp deep link — replace with real number (include country code, no spaces or dashes)
VITE_WHATSAPP_URL=https://wa.me/201234567890

# Formspree form ID — create a form at formspree.io and paste the 8-char ID here
VITE_FORMSPREE_FORM_ID=xyzabcde

# Navara Backend API base URL — points at the Express server
VITE_API_BASE_URL=http://localhost:3001
